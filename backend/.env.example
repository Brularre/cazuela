SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-service-role-key

# Meta — WhatsApp webhook + OTP sending
META_APP_SECRET=your-meta-app-secret
META_PHONE_NUMBER_ID=your-phone-number-id
META_ACCESS_TOKEN=your-permanent-access-token
META_WEBHOOK_VERIFY_TOKEN=pick-any-random-string

# Dashboard auth — any long random string (32+ chars)
SESSION_SECRET=replace-with-a-long-random-string

# Export endpoint protection
EXPORT_TOKEN=replace-with-a-secret-token

# AI agent — optional, enables Claude Haiku for expense categorization
ANTHROPIC_API_KEY=sk-ant-your-key-here
USE_AI_AGENT=false

# Dashboard URL — sent to users via the 'tablero' WhatsApp command
DASHBOARD_URL=https://your-frontend.up.railway.app
